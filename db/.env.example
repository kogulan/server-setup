# DB Settings
# IMPORTANT: If you are manually creating a .env file, ensure you use strong, unique passwords.
# If using the setup.sh script, these will be automatically generated for you.
POSTGRES_USER=admin
POSTGRES_PASSWORD=<REPLACE_WITH_SECURE_PASSWORD>
MARIADB_ROOT_PASSWORD=<REPLACE_WITH_SECURE_PASSWORD>
DB_MEMORY_LIMIT=512M

# Adminer
ADMINER_PORT=8080
