# FTP Settings
# IMPORTANT: If you are manually creating a .env file, ensure you use strong, unique passwords.
# If using the setup.sh script, these will be automatically generated for you.
FTP_PUBLIC_HOST=your_server_ip
FTP_WEB_USER=webuser
FTP_WEB_PASS=<REPLACE_WITH_SECURE_PASSWORD>
FTP_FILES_USER=filesuser
FTP_FILES_PASS=<REPLACE_WITH_SECURE_PASSWORD>
