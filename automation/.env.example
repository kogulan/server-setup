# Automation Services Settings
# IMPORTANT: If you are manually creating a .env file, ensure you use strong, unique passwords.
# If using the setup.sh script, these will be automatically generated for you.
AUTOMATION_MEMORY_LIMIT=512M
HUGINN_MEMORY_LIMIT=1G

# n8n
N8N_DB=n8n
N8N_DB_USER=n8n_user
N8N_DB_PASS=<REPLACE_WITH_SECURE_PASSWORD>
N8N_PORT_EXTERNAL=5678

# Activepieces
AP_DB=activepieces
AP_DB_USER=ap_user
AP_DB_PASS=<REPLACE_WITH_SECURE_PASSWORD>
AP_PORT_EXTERNAL=8081
AP_URL=http://yourdomain.com:8081

# Huginn
HUGINN_DB=huginn
HUGINN_DB_USER=huginn_user
HUGINN_DB_PASS=<REPLACE_WITH_SECURE_PASSWORD>
HUGINN_DOMAIN=yourdomain.com:3000
HUGINN_PORT_EXTERNAL=3000
